# ============================================================
# Attendify Backend — Environment Variables
# Copy this file to .env and fill in values for local dev.
# On Render, set these as Environment Variables in the dashboard.
# ============================================================

# Flask / App
SECRET_KEY=change_me_to_a_random_64_char_string
FLASK_ENV=production

# JWT
JWT_SECRET_KEY=change_me_to_another_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# PostgreSQL — Render provides this automatically when you attach a DB
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://attendify_user:password@localhost:5432/attendify_db

# FaceNet Microservice URL (also on Render)
FACE_SERVICE_URL=https://your-facenet-service.onrender.com

# Geofencing
GEOFENCE_RADIUS_METERS=100

# Face Recognition
MATCH_THRESHOLD=0.55

# CORS — set to your Vercel/frontend URL(s)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000,http://localhost:3001,http://localhost:3002

# File storage for face embeddings (Render persistent disk path)
EMBEDDINGS_PATH=/opt/render/project/src/embeddings.pkl
