# ============================================================
# Attendify Frontend — Environment Variables
# Copy to .env.local for local dev.
# On Vercel, set these in Project Settings → Environment Variables.
# ============================================================

# Your Render backend URL (no trailing slash)
# The Next.js proxy routes will add /api as needed.
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Your FaceNet service URL (used server-side in API routes)
FACENET_SERVICE_URL=https://your-facenet-service.onrender.com

# NextAuth / JWT secret (must match backend JWT_SECRET_KEY)
NEXTAUTH_SECRET=change_me_to_same_as_backend_jwt_secret

# App URL (set to your Vercel deployment URL)
NEXTAUTH_URL=https://your-app.vercel.app
